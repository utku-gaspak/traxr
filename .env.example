# Frontend build-time API URL. Vite bakes this into the static bundle.
VITE_API_BASE_URL=https://api.traxr.xyz

# Backend runtime configuration.
POSTGRES_DB=jobtracker
POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_DATABASE_PASSWORD
JWT__Issuer=https://api.traxr.xyz
JWT__Audience=https://api.traxr.xyz
JWT__SigningKey=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_BYTES

# Browser origins allowed to call the API.
Cors__AllowedOrigins__0=https://traxr.xyz
Cors__AllowedOrigins__1=https://www.traxr.xyz
